# Copy this file to ".env" in the project root and fill in your real values.
# docker-compose automatically reads ".env" from the project root.

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=your-bucket-name

# Stripe test-mode secret key (starts with sk_test_...)
# Get it from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your-test-secret-key
